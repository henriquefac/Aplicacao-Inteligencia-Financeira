# --- CONFIGURAÇÕES DE IA (BACKEND) ---
# Chave da API do OpenRouter (Obrigatório se LLM_PROVIDER for openrouter)
# Obtenha em: https://openrouter.ai/keys
OPENROUTER_API_KEY=sua_chave_aqui

# Provedor de LLM: "ollama", "openai" ou "openrouter"
LLM_PROVIDER=openrouter

# Modelo para o Ollama (usado como fallback se provider for openrouter)
LLM_MODEL=mistral

# URL base do Ollama
# Para Docker use: http://ollama:11434
# Para Local use: http://localhost:11434
LLM_BASE_URL=http://ollama:11434

# Host do Ollama para o container de pull de modelos
OLLAMA_HOST=ollama

# --- CONFIGURAÇÕES DO FRONTEND ---
# URL base da API do Backend
# Para Docker use: http://backend:8000
# Para Local use: http://localhost:8000
BASE_URL=http://backend:8000

# Modelo de embedding (Ollama)
EMBEDDING_MODEL=nomic-embed-text

# Armazenamento de vetores (RAG): "faiss" ou "json"
VECTOR_STORE=json

# --- OUTRAS CONFIGURAÇÕES ---
# Se True, apaga os dados ao desligar o backend (útil para testes)
CLEAR_DATA_ON_SHUTDOWN=False
